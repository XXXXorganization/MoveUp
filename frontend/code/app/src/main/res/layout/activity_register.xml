<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    tools:context=".Register">

    <!-- 标题：Register -->

    <!-- 用户名输入框 -->
    <TextView
        android:id="@+id/tv_register_title1"
        android:layout_width="245dp"
        android:layout_height="108dp"
        android:layout_marginTop="76dp"
        android:text="Create an account"
        android:textColor="#191A1C"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.339"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/et_username1"
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:hint="User Name"
        android:textColorHint="#191A1C"
        android:textColor="#191A1C"
        android:backgroundTint="#C7FB58"
        android:paddingStart="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_register_title1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp"/>

    <!-- 密码输入框 -->
    <EditText
        android:id="@+id/et_password1"
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:textColorHint="#191A1C"
        android:textColor="#191A1C"
        android:backgroundTint="#C7FB58"
        android:paddingStart="12dp"
        app:layout_constraintTop_toBottomOf="@id/et_username1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- 确认密码输入框 -->
    <EditText
        android:id="@+id/et_confirm_pwd1"
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:textColorHint="#191A1C"
        android:textColor="#191A1C"
        android:backgroundTint="#C7FB58"
        android:paddingStart="12dp"
        app:layout_constraintTop_toBottomOf="@id/et_password1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- 注册按钮 -->
    <Button
        android:id="@+id/btn_register_confirm1"
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:text="Register"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C7FB58"
        app:layout_constraintTop_toBottomOf="@id/et_confirm_pwd1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>