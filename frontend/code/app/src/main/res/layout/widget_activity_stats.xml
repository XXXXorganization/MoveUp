<?xml version="1.0" encoding="utf-8"?>
<!-- 与 Main 中活动卡片共用的 Time / Pace / 距离统计条 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/timeValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/activity_time_value"
        android:textColor="@color/time_highlight"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/timeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_time"
        android:textColor="@color/grey_secondary"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/timeValue"
        app:layout_constraintTop_toBottomOf="@id/timeValue" />

    <TextView
        android:id="@+id/paceValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:text="@string/activity_pace_value"
        android:textColor="@color/pace_highlight"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/timeValue"
        app:layout_constraintTop_toTopOf="@id/timeValue" />

    <TextView
        android:id="@+id/paceLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_pace"
        android:textColor="@color/grey_secondary"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/paceValue"
        app:layout_constraintTop_toBottomOf="@id/paceValue" />

    <TextView
        android:id="@+id/distanceValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/activity_distance"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/timeValue" />

    <View
        android:id="@+id/distanceUnderline"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:layout_marginTop="6dp"
        android:background="@color/lime_underline"
        app:layout_constraintEnd_toEndOf="@id/distanceValue"
        app:layout_constraintStart_toStartOf="@id/distanceValue"
        app:layout_constraintTop_toBottomOf="@id/distanceValue" />

</androidx.constraintlayout.widget.ConstraintLayout>
